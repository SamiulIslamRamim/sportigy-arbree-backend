// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  

}

enum UserRole {
  player
  organization
}

enum BattingStyle {
  RIGHT_HAND_BAT @map("Right-hand bat")
  LEFT_HAND_BAT  @map("Left-hand bat")
}

enum BowlingStyle {
  RIGHT_ARM_FAST      @map("Right-arm fast")
  LEFT_ARM_FAST       @map("Left-arm fast")
  LEFT_ARM_SPIN       @map("Left-arm spin")
  RIGHT_ARM_SPIN       @map("Right-arm spin")
  NONE                @map("None")
}

enum CricketPlayingRole {
  WICKET_KEEPER @map("Wicket Keeper")
  BATSMAN       @map("Batsman")
  BOWLER        @map("Bowler")
  ALL_ROUNDER   @map("All Rounder")
}

model User {
  id           String      @id @default(uuid()) @db.Uuid
  email        String      @unique
  username     String     @unique
  passwordHash String      @map("password_hash")
  role         UserRole      @default(player)
  name         String?
  contactNo    String?     @map("contact_no")
  height       String?
  weight       String?
  birthday     DateTime?   @db.Date
  categories   String[]
  websiteUrl   String?     @map("website_url")
  city         String?
  state        String?
  country      String?
  isActive     Boolean     @default(true) @map("is_active")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  //relations
  refreshTokens RefreshToken[]
  cricketProfile CricketProfile?

  @@map("users")
}


model CricketProfile {
  id            String               @id @default(uuid()) @db.Uuid

  userId        String               @unique @db.Uuid
  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade) //fk fk

  playingRole   CricketPlayingRole?
  battingStyle  BattingStyle?
  bowlingStyle  BowlingStyle?
  academy       String?
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")

  @@map("cricket_profiles")
}







model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  token     String   @unique
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("refresh_tokens")
}

model PasswordReset {
  id        String   @id @default(uuid()) @db.Uuid
  email     String
  otp       String
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("password_resets")
}

model Category {
  id   String @id @default(uuid()) @db.Uuid
  name String @unique

  @@map("categories")
}

model OrgCategory {
  id   String @id @default(uuid()) @db.Uuid
  name String @unique

  @@map("org_categories")
}

model PendingRegistration {
  id        String   @id @default(uuid()) @db.Uuid
  email     String
  username  String
  otp       String
  payload   Json
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("pending_registrations")
}